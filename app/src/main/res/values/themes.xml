<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.IGrab" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_pink</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/card_bg</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="textInputStyle">@style/Widget.Material3.TextInputLayout.OutlinedBox</item>
    </style>

    <style name="Theme.IGrab.Dialog" parent="Theme.Material3.Dark.Dialog">
        <item name="colorPrimary">@color/accent_pink</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:background">@color/card_bg</item>
    </style>

</resources>
