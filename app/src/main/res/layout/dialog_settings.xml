<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="URL do Servidor"
        android:textSize="12sp"
        android:textColor="#A0A0C0"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:hint="http://localhost:5000"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/settingsServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textColor="#E0E0F0" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cookies do Instagram (opcional)"
        android:textSize="12sp"
        android:textColor="#A0A0C0"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Necessário para contas privadas e Stories. Exporte com a extensão 'Get cookies.txt LOCALLY' no Chrome."
        android:textSize="11sp"
        android:textColor="#606080"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:hint="Cole o cookies.txt aqui...">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/settingsCookies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#E0E0F0" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
