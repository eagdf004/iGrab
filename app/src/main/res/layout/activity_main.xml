<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ══ HEADER ════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IGrab"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/syne_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Downloader via gallery-dl"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Botão configurações -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="⚙️"
                android:textSize="18sp"
                android:padding="0dp"
                app:backgroundTint="@color/surface"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginEnd="8dp"/>

            <!-- Chip de status do servidor -->
            <com.google.android.material.chip.Chip
                android:id="@+id/serverChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verificando..."
                android:textSize="11sp"
                app:chipMinHeight="32dp"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!-- ══ BANNER: servidor offline ═══════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/serverBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1A2A0A"
            app:strokeColor="#4A8A1A"
            app:strokeWidth="1dp"
            app:cardCornerRadius="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="⚠️ Servidor offline. Abra o Termux e rode:\n\npython ~/ig-downloader/app.py"
                android:textSize="12sp"
                android:textColor="#AAFFAA"
                android:fontFamily="monospace" />
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ INPUT CARD ══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/inputCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/urlInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://www.instagram.com/p/..."
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:startIconDrawable="@drawable/ic_link"
                    app:startIconTint="@color/accent_pink"
                    app:boxStrokeColor="@color/accent_pink"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/urlInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:textColor="@color/text_primary"
                        android:imeOptions="actionDone" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownload"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="⬇  Baixar"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/gradient_start"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ PROGRESS CARD ═══════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/progressCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- URL sendo baixada + badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/progressUrl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted"
                        android:ellipsize="end"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/statusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏳ Baixando..."
                        android:textSize="11sp"
                        android:textColor="@color/text_primary"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/badge_running"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- Log header com toggle -->
                <LinearLayout
                    android:id="@+id/logHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Log do download"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/logArrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▼"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted" />
                </LinearLayout>

                <!-- Log scroll -->
                <ScrollView
                    android:id="@+id/logScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@color/bg_dark"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/logBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="#88AAFFAA"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.4" />
                </ScrollView>

                <!-- Botão nova URL -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNewDownload"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Nova URL"
                    android:textSize="14sp"
                    android:layout_marginTop="14dp"
                    app:backgroundTint="@color/surface"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@color/card_border"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ RESULT CARD (mídias baixadas) ══════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/card_border"
            app:strokeWidth="1dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ARQUIVOS BAIXADOS"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/mediaGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ HISTÓRICO ══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/historySection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HISTÓRICO"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/historyList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
